# Kopie als pipeline/.env anlegen (nie committen!).
# In GitHub Actions kommen dieselben Werte aus Repository-Secrets.

# DIP-API des Bundestags. Es gibt einen öffentlich dokumentierten generischen Key
# (https://dip.bundestag.de -> Hilfe -> DIP-API), der regelmäßig rotiert.
# Eigenen Key per Mail an die Bundestagsverwaltung beantragen (siehe API-Doku).
DIP_API_KEY=

# Claude API für Anreicherung (Zusammenfassung/Tagging/Relevanz) und Briefing.
# Ohne Key läuft die Pipeline regelbasiert weiter (degradiert, aber funktionsfähig).
ANTHROPIC_API_KEY=
LLM_ENRICH=1
ANTHROPIC_MODEL_ENRICH=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_BRIEF=claude-sonnet-4-6
# Budget-Kappung: max. LLM-angereicherte Dokumente pro Lauf
LLM_MAX_DOCS_PER_RUN=150

# Pfad zur SQLite-Datenbank (relativ zu pipeline/)
DB_PATH=db/energie-kompass.db

# 1 = Repo/Hosting ist privat -> private-use-only-Inhalte dürften projiziert werden.
# Repo ist aktuell PUBLIC -> auf 0 lassen!
HOSTING_PRIVATE=0
